[flake8]
max-line-length = 100
extend-ignore =
    # E203: whitespace before ':' — conflicts with black
    E203,
    # W503: line break before binary operator — conflicts with black
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    modules/backend/migrations/versions,
per-file-ignores =
    # Allow unused imports in __init__.py (re-exports)
    __init__.py:F401
