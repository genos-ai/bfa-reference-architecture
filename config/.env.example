# =============================================================================
# Secrets Template
# =============================================================================
# Copy this file to .env and fill in the values.
# This file contains ONLY secrets (passwords, tokens, keys).
# All other configuration lives in config/settings/*.yaml files.
# NEVER commit .env to version control.
# =============================================================================

# Database password
DB_PASSWORD=

# Redis password (empty for no auth)
REDIS_PASSWORD=

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# API key hashing salt (generate with: openssl rand -hex 16)
API_KEY_SALT=

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram webhook secret
TELEGRAM_WEBHOOK_SECRET=

# LLM provider API key (for PydanticAI agents)
# Supports: ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY
# Only one is required, matching the model in config/agents/*.yaml
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Test configuration (optional; used by pytest only)
# -----------------------------------------------------------------------------
# When set, pytest uses this URL for the test database. When unset, tests use
# the database_url from config/settings/test.yaml (default: in-memory SQLite).
# Example for PostgreSQL: postgresql+asyncpg://user:pass@localhost/test_db
# TEST_DATABASE_URL=
